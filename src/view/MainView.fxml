<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="view.MainController"
            styleClass="root-pane">

    <top>
        <VBox spacing="8" styleClass="header-box" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16" right="18" bottom="12" left="18"/>
            </padding>

            <Label fx:id="appTitleLabel" text="ToDoList" styleClass="app-title"/>
            <Label fx:id="insightLabel" text="Ближайший старт: ..." styleClass="insight-label" wrapText="true"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Поиск" styleClass="field-label"/>
                <TextField fx:id="searchField" HBox.hgrow="ALWAYS" promptText="Поиск по заголовку, описанию или категории"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button fx:id="addButton" text="Добавить" onAction="#handleAddTask" styleClass="btn-success"/>
                <Button fx:id="editButton" text="Редактировать" onAction="#handleEditTask"/>
                <Button fx:id="deleteButton" text="Удалить" onAction="#handleDeleteTask" styleClass="btn-danger"/>

                <MenuButton fx:id="bulkMenuButton" text="Групповые действия">
                    <items>
                        <MenuItem fx:id="bulkCompleteItem" text="Отметить выполненными" onAction="#handleBulkComplete"/>
                        <MenuItem fx:id="bulkPriorityItem" text="Изменить приоритет" onAction="#handleBulkPriority"/>
                        <MenuItem fx:id="bulkCategoryItem" text="Изменить категорию" onAction="#handleBulkCategory"/>
                        <MenuItem fx:id="bulkDeleteItem" text="Удалить выбранные" onAction="#handleBulkDelete"/>
                    </items>
                </MenuButton>

                <Button fx:id="sortByDateButton" text="По дате" onAction="#sortByDate"/>
                <Button fx:id="sortByPriorityButton" text="По приоритету" onAction="#sortByPriority"/>
                <Button fx:id="focusButton" text="Фокус дня" onAction="#handleFocusMode" styleClass="btn-accent"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Выход" onAction="#handleExit" styleClass="btn-neutral"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
            <tabs>
                <Tab text="Задачи">
                    <VBox spacing="10" styleClass="table-box" BorderPane.alignment="CENTER">
                        <padding>
                            <Insets top="0" right="18" bottom="12" left="18"/>
                        </padding>
                        <TableView fx:id="taskTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="titleColumn" text="Задача" prefWidth="210"/>
                                <TableColumn fx:id="descriptionColumn" text="Описание" prefWidth="300"/>
                                <TableColumn fx:id="deadlineColumn" text="Дедлайн" prefWidth="170"/>
                                <TableColumn fx:id="priorityColumn" text="Приоритет" prefWidth="120"/>
                                <TableColumn fx:id="categoryColumn" text="Категория" prefWidth="130"/>
                                <TableColumn fx:id="statusColumn" text="Готово" prefWidth="80"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>
                <Tab text="Календарь">
                    <BorderPane>
                        <left>
                            <VBox spacing="10" styleClass="table-box" BorderPane.alignment="CENTER_LEFT">
                                <padding>
                                    <Insets top="12" right="12" bottom="12" left="18"/>
                                </padding>
                                <Label text="Выберите дату" styleClass="field-label"/>
                                <DatePicker fx:id="calendarPicker" onAction="#handleCalendarDateChange"/>
                                <Button fx:id="calendarAddButton" text="Добавить задачу" onAction="#handleAddTaskForDate"/>
                                <Button fx:id="calendarExportButton" text="Экспортировать в .ics" onAction="#handleExportCalendar"/>
                                <Label fx:id="calendarSummaryLabel" text="" wrapText="true"/>
                            </VBox>
                        </left>
                        <center>
                            <VBox spacing="8" styleClass="table-box" BorderPane.alignment="CENTER">
                                <padding>
                                    <Insets top="12" right="18" bottom="12" left="12"/>
                                </padding>
                                <Label text="Задачи на дату" styleClass="field-label"/>
                                <ListView fx:id="calendarTaskList" VBox.vgrow="ALWAYS"/>
                            </VBox>
                        </center>
                    </BorderPane>
                </Tab>
                <Tab text="Статистика">
                    <ScrollPane fitToWidth="true" fitToHeight="true">
                        <VBox spacing="14" styleClass="table-box">
                            <padding>
                                <Insets top="12" right="18" bottom="12" left="18"/>
                            </padding>
                            <HBox spacing="12">
                                <PieChart fx:id="completionChart" prefHeight="260" prefWidth="320" title="Статусы"/>
                                <PieChart fx:id="categoryChart" prefHeight="260" prefWidth="320" title="Категории"/>
                            </HBox>
                            <BarChart fx:id="priorityChart" prefHeight="240" title="Приоритеты">
                                <xAxis>
                                    <CategoryAxis label="Приоритет"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Кол-во"/>
                                </yAxis>
                            </BarChart>
                            <LineChart fx:id="timelineChart" prefHeight="240" title="Задачи на 7 дней">
                                <xAxis>
                                    <CategoryAxis label="Дата"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Кол-во"/>
                                </yAxis>
                            </LineChart>
                        </VBox>
                    </ScrollPane>
                </Tab>
                <Tab text="Настройки">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="14" styleClass="table-box">
                            <padding>
                                <Insets top="12" right="18" bottom="12" left="18"/>
                            </padding>

                            <TitledPane text="Темы" expanded="true">
                                <VBox spacing="10">
                                    <padding>
                                        <Insets top="10" right="10" bottom="10" left="10"/>
                                    </padding>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Тема" styleClass="field-label"/>
                                        <ComboBox fx:id="themeCombo" prefWidth="200"/>
                                    </HBox>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Фон" styleClass="field-label"/>
                                        <ColorPicker fx:id="customBgColorPicker"/>
                                        <Label text="Акцент" styleClass="field-label"/>
                                        <ColorPicker fx:id="customAccentColorPicker"/>
                                    </HBox>
                                    <Button fx:id="saveCustomThemeButton" text="Сохранить кастомную тему" onAction="#handleSaveCustomTheme"/>
                                </VBox>
                            </TitledPane>

                            <TitledPane text="Уведомления" expanded="false">
                                <VBox spacing="10">
                                    <padding>
                                        <Insets top="10" right="10" bottom="10" left="10"/>
                                    </padding>
                                    <HBox spacing="16">
                                        <CheckBox fx:id="notifyPopupCheck" text="Всплывающее окно"/>
                                        <CheckBox fx:id="notifySoundCheck" text="Звук"/>
                                        <CheckBox fx:id="notifyEmailCheck" text="Email"/>
                                    </HBox>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Напоминание" styleClass="field-label"/>
                                        <Spinner fx:id="reminderValueSpinner" prefWidth="100"/>
                                        <ChoiceBox fx:id="reminderUnitChoice"/>
                                        <Label text="(0 = по умолчанию)"/>
                                    </HBox>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Email" styleClass="field-label"/>
                                        <TextField fx:id="notifyEmailField" promptText="user@example.com" HBox.hgrow="ALWAYS"/>
                                    </HBox>
                                    <Button fx:id="saveNotificationButton" text="Сохранить настройки" onAction="#handleSaveNotificationSettings"/>
                                </VBox>
                            </TitledPane>

                            <TitledPane text="Музыка" expanded="false">
                                <VBox spacing="10">
                                    <padding>
                                        <Insets top="10" right="10" bottom="10" left="10"/>
                                    </padding>
                                    <CheckBox fx:id="musicEnabledCheck" text="Включить фоновую музыку"/>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Громкость" styleClass="field-label"/>
                                        <Slider fx:id="volumeSlider" min="0" max="1" value="0.35" prefWidth="200"/>
                                    </HBox>
                                    <Label fx:id="audioCountLabel" text="Треков: 0"/>
                                </VBox>
                            </TitledPane>

                            <TitledPane text="Виджет" expanded="false">
                                <VBox spacing="10">
                                    <padding>
                                        <Insets top="10" right="10" bottom="10" left="10"/>
                                    </padding>
                                    <CheckBox fx:id="widgetEnabledCheck" text="Показывать виджет"/>
                                    <Button fx:id="widgetRefreshButton" text="Обновить виджет"/>
                                </VBox>
                            </TitledPane>
                        </VBox>
                    </ScrollPane>
                </Tab>
            </tabs>
        </TabPane>
    </center>

    <bottom>
        <HBox styleClass="status-box" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="8" right="18" bottom="14" left="18"/>
            </padding>
            <Label fx:id="statusLabel" text="Всего: 0 | Выполнено: 0 | Просрочено: 0" styleClass="status-label"/>
        </HBox>
    </bottom>

</BorderPane>
