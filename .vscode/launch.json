{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Launch ToDoList App",
            "request": "launch",
            "mainClass": "app.MainApp",
            "projectName": "ToDoList",
            "vmArgs": "--module-path ${workspaceFolder}/.javafx/lib --add-modules javafx.controls,javafx.fxml,javafx.media --enable-native-access=javafx.graphics",
            "args": "",
            "console": "internalConsole",
            "stopOnEntry": false,
            "preLaunchTask": "build"
        },
        {
            "type": "java",
            "name": "Launch Current File",
            "request": "launch",
            "mainClass": "${file}"
        }
    ]
}
